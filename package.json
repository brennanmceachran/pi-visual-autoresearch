{
  "name": "pi-visual-autoresearch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local battleground for Pi autoresearch with a visual diff metric.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "battleground": "tsx src/server/index.ts",
    "battleground:stop": "node scripts/battleground-stop.mjs",
    "pi": "node scripts/pi-local.mjs",
    "research:agent": "node scripts/pi-local.mjs \"Use the visual-diff-autoresearch skill to optimize the current target image in this repository.\"",
    "battleground:reset": "node scripts/battleground-reset.mjs",
    "research:score": "tsx src/research/score.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "0.58.3",
    "@mariozechner/pi-coding-agent": "0.58.3",
    "@mariozechner/pi-tui": "0.58.3",
    "@sinclair/typebox": "^0.34.0",
    "express": "^5.0.0",
    "image-size": "^2.0.0",
    "multer": "^2.0.0",
    "playwright": "^1.50.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
